source "https://rubygems.org"

# This gem tracks exactly what GitHub Pages runs, so a local build
# matches what gets deployed. Run `bundle install` once, then
# `bundle exec jekyll serve` to preview locally.
gem "github-pages", group: :jekyll_plugins

# Windows / JRuby compatibility helpers (harmless elsewhere)
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :mswin, :x64_mingw]
